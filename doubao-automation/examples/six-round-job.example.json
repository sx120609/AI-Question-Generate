      }
    },
    {
      "prompt": "填写与首轮直接相关、能够补足证据或交付物的第2轮追问。",
      "evaluation": {
        "vote": "like",
        "labels": ["内容准确", "其他"],
        "note": "填写针对第2轮实际回复的具体评价，说明哪些内容可用以及还缺少什么。"
      }
    },
    {
      "prompt": "填写第3轮相关追问。",
      "evaluation": {
        "vote": "like",
        "labels": ["易于理解", "其他"],
        "note": "填写针对第3轮实际回复的具体评价，不能复用上一轮的理由。"
      }
    },
    {
      "prompt": "填写第4轮相关追问。",
      "evaluation": {
        "vote": "like",
        "labels": ["内容完善", "其他"],
        "note": "填写针对第4轮实际回复的具体评价，并指出本轮对最终交付的增益。"
      }
    },
    {
      "prompt": "填写第5轮相关追问。",
      "evaluation": {
        "vote": "like",
        "labels": ["内容准确", "其他"],
        "note": "填写针对第5轮实际回复的具体评价，并说明是否仍有关键缺口。"
      }
    },
    {
      "prompt": "填写第6轮收敛追问，要求形成可使用的最终交付。",
      "evaluation": {
        "vote": "like",
        "labels": ["内容准确", "易于理解", "内容完善", "其他"],
        "note": "填写针对最终回复的具体评价，说明最终交付是否可以直接使用。"
      }
    }
  ]
