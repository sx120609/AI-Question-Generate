{
  "version": 5,
  "policyId": "l2-corpus-calibrated-source-driven-v5",
  "questionLength": {
    "hardMinimumVisibleCharacters": 700,
    "minimumCoreSceneCharacters": 300,
    "recommendedMinimumVisibleCharacters": 800,
