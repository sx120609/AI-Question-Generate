      "informationOrder": 0.08,
      "decisionForm": 0.06,
      "evidenceTopology": 0.06,
      "artifactTopology": 0.1,
      "stepActions": 0.12,
      "flowTopology": 0.08,
      "sentenceRhythm": 0.05,
      "lexicalSkeleton": 0.25,
      "narrativeLexical": 0.16
    }
  },
  "lexicalDuplication": {
    "questionHardThreshold": 0.68,
